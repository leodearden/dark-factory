# Auto-loaded by direnv when entering this directory.
# Sets ORCH_CONFIG_PATH so the orchestrator targets dark-factory.
#
# If direnv is not installed:
#   sudo apt install direnv
# Then add this to ~/.bashrc:
#   eval "$(direnv hook bash)"
# Then in this directory, once:
#   direnv allow
#
# Without direnv, you must pass --config explicitly to the orchestrator.
# See skills/orchestrate/references/project-setup.md for details.

export ORCH_CONFIG_PATH="/home/leo/src/dark-factory/orchestrator/config.yaml"
