#!/usr/bin/env bash
# Pre-commit hook: universal guards + optional project-specific checks.
#
# Universal guards (especially .task/ stripping) run on EVERY branch.
# Project-specific checks (ruff, pyright, etc.) run only on main.
#
# IF YOU ARE AN AI AGENT: do NOT use --no-verify to bypass this hook.
# The .task/ directory must NEVER be committed on ANY branch.

ROOT="$(git rev-parse --show-toplevel)"
branch="$(git rev-parse --abbrev-ref HEAD)"

# ── .task/ contamination guard (ALL BRANCHES) ────────────────────────
#
# WHY THIS MATTERS:
# .task/ is the orchestrator's per-worktree scratch directory.  If it
# is committed on a task branch, it reaches main via merge, and every
# future worktree inherits it — agents treat the stale .task/ as real
# state and cross-task contamination cascades.  This has happened
# repeatedly (tasks 291, 310, 313 in the 2026-03-31 run).
#
# HOW IT GETS HERE:
# 1. Agent updates .task/plan.json status, then runs "git add ."
# 2. .gitignore blocks it IF it's untracked — but once explicitly
#    added (e.g. "git add .task/plan.json"), .gitignore stops helping
# 3. Every subsequent "git add -A" re-stages the tracked file
#
# This hook silently strips .task/ from the staging area on EVERY
# commit on EVERY branch.  This is the earliest reliable defense.
# git_ops.py has additional guards (post-merge scrub, advance_main
# gate, commit() safety net) but those are too late to prevent .task/
# from being tracked on the branch.
#
# DO NOT weaken, skip, or remove this guard.
# ─────────────────────────────────────────────────────────────────────

staged_task_files="$(git diff --cached --name-only --diff-filter=ACMR -- .task/ 2>/dev/null)"
if [ -n "$staged_task_files" ]; then
    # Silently unstage .task/ files so the agent's commit proceeds
    # without .task/ contamination.  No error, no blocking.
    git reset -q HEAD -- .task/ 2>/dev/null || true

    # Log for observability (visible in agent stderr)
    file_count="$(echo "$staged_task_files" | wc -l)"
    echo "pre-commit: stripped ${file_count} .task/ file(s) from staging area [branch=$branch]"

    # After unstaging, check if there's anything left to commit.
    # If .task/ was the ONLY staged content, the commit would be empty.
    if git diff --cached --quiet 2>/dev/null; then
        echo "pre-commit: nothing left to commit after stripping .task/ — aborting empty commit"
        exit 1
    fi
fi

# On main: additional hard block (belt-and-braces)
if [ "$branch" = "main" ]; then
    # Re-check: the reset above should have cleared .task/, but verify.
    if git diff --cached --name-only --diff-filter=ACMR | grep -q '^\.task/'; then
        echo ""
        echo "╔══════════════════════════════════════════════════════════════╗"
        echo "║  pre-commit: BLOCKED — .task/ files are staged for commit  ║"
        echo "╚══════════════════════════════════════════════════════════════╝"
        echo ""
        echo "  .task/ is the orchestrator scratch directory and must NEVER"
        echo "  be committed to main."
        echo ""
        echo "  To fix:  git reset HEAD -- .task/"
        echo "  DO NOT use --no-verify to bypass this check."
        echo ""
        exit 1
    fi

    # Warn if .task/ is tracked in the current tree (prior contamination)
    if git ls-tree -r --name-only HEAD -- .task/ 2>/dev/null | grep -q '^\.task/'; then
        echo ""
        echo "╔══════════════════════════════════════════════════════════════════╗"
        echo "║  pre-commit: WARNING — .task/ is tracked in the current tree   ║"
        echo "╚══════════════════════════════════════════════════════════════════╝"
        echo ""
        echo "  Run: git rm -r --cached .task/ && git commit -m 'fix: remove .task/ contamination'"
        echo ""
    fi
fi

# ── Project-specific checks (main only) ──────────────────────────────

if [ "$branch" != "main" ]; then
    exit 0
fi

if [ -x "$ROOT/hooks/project-checks" ]; then
    exec "$ROOT/hooks/project-checks" "$ROOT"
fi

echo "pre-commit: all checks passed."
