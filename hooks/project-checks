#!/usr/bin/env bash
# dark-factory project-specific checks (called from pre-commit).
# Receives repo root as $1.

ROOT="${1:?}"
echo "pre-commit: linting (main branch)..."

# All first-party packages (for ruff)
ALL_PACKAGES=(shared escalation fused-memory orchestrator dashboard)
# Packages with [tool.pyright] config (pyright runs per-package from its directory)
PYRIGHT_PACKAGES=(fused-memory orchestrator dashboard)

DIRS=()
for pkg in "${ALL_PACKAGES[@]}"; do
    [ -d "$ROOT/$pkg" ] && DIRS+=("$ROOT/$pkg")
done

# ruff check (runs from repo root, all packages at once)
if ! uv run ruff check --quiet "${DIRS[@]}"; then
    echo "pre-commit: ruff check failed. Fix lint errors before committing to main."
    exit 1
fi

# asyncmock assertion-style check (fused-memory/tests only)
echo "pre-commit: asyncmock assertion-style check..."
if ! (cd "$ROOT" && python3 fused-memory/scripts/check_asyncmock_assertion_style.py fused-memory/tests); then
    echo "pre-commit: asyncmock style check failed. Use assert_not_awaited() instead of assert_not_called() on AsyncMocks."
    exit 1
fi

# pyright (must run from each package directory to pick up [tool.pyright] config)
for pkg in "${PYRIGHT_PACKAGES[@]}"; do
    dir="$ROOT/$pkg"
    [ -d "$dir" ] || continue
    echo "  pyright: $pkg"
    if ! (cd "$dir" && uv run pyright); then
        echo "pre-commit: pyright failed in $pkg. Fix type errors before committing to main."
        exit 1
    fi
done

echo "pre-commit: all checks passed."
