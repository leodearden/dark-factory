{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp",
        "--headless",
        "--caps", "vision",
        "--viewport-size", "1280x900"
      ]
    },
    "escalation": {
      "type": "http",
      "url": "http://127.0.0.1:8102/mcp"
    },
    "fused-memory": {
      "type": "http",
      "url": "http://127.0.0.1:8002/mcp"
    }
  }
}
