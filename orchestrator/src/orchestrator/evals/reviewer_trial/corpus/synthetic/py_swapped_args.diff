+    async def get_diff_stats(self, from_sha: str, to_sha: str) -> dict[str, int]:
+        """Return insertions/deletions stats between two commits."""
+        _, output, _ = await _run(
+            ['git', 'diff', '--shortstat', from_sha, to_sha],
