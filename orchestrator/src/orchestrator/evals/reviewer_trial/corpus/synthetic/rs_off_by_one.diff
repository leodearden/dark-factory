     }

     simplex
 }
+
+/// Validate that a simplex has the correct number of vertices for N dimensions.
+fn validate_simplex(simplex: &[Vec<f64>], n: usize) -> bool {
+    simplex.len() == n + 1
+        && simplex.iter().all(|v| v.len() == n)
