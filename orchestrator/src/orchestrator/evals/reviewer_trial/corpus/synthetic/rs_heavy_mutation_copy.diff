+/// Construct a solution map from parameter specifications and their computed values.
+///
+/// Converts each auto-parameter / solution-value pair into a `(ValueCellId, Value)`
+/// entry with the appropriate SI dimension.  Panics if the input slices differ in
+/// length.
+fn create_solution_map(
+    specifications: &[AutoParam],
+    solution_values: &[f64],
+) -> HashMap<ValueCellId, Value> {
+    assert_eq!(
+        specifications.len(),
+        solution_values.len(),
+        "specifications and solution_values must have the same length",
+    );
+    specifications
+        .iter()
+        .zip(solution_values.iter())
+        .map(|(spec, &computed_val)| {
+            (
+                spec.id.clone(),
+                Value::Scalar {
+                    si_value: computed_val,
+                    dimension: dimension_of(&spec.param_type),
+                },
+            )
+        })
+        .collect()
+}
