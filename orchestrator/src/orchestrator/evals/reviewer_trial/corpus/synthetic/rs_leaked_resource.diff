+/// Export mesh to a temporary file descriptor for streaming to a client.
+///
+/// Returns the raw fd that the caller can pass to a socket send operation.
+/// The caller is responsible for closing the fd when done.
+pub fn export_stl_to_fd(mesh: &Mesh, fd: i32) -> Result<usize> {
+    // SAFETY: caller guarantees fd is valid and open
+    let file = unsafe { File::from_raw_fd(fd) };
+    let mut writer = BufWriter::new(file);
+
+    let vertices = mesh.vertices();
+    let triangles = mesh.triangles();
+
+    // STL binary header (80 bytes + triangle count)
+    let header = [0u8; 80];
+    writer.write_all(&header)?;
+    let tri_count = (triangles.len() / 3) as u32;
+    writer.write_all(&tri_count.to_le_bytes())?;
+
+    let mut bytes_written: usize = 84;
+    for tri in triangles.chunks(3) {
+        // Normal placeholder (0,0,0) — viewer will recompute
+        writer.write_all(&[0u8; 12])?;
+        for &idx in tri {
+            let v = &vertices[idx as usize];
+            writer.write_all(&(v.x as f32).to_le_bytes())?;
+            writer.write_all(&(v.y as f32).to_le_bytes())?;
+            writer.write_all(&(v.z as f32).to_le_bytes())?;
+        }
+        // Attribute byte count
+        writer.write_all(&0u16.to_le_bytes())?;
+        bytes_written += 50;
+    }
+
+    writer.flush()?;
+    // BufWriter drops here, which drops the inner File, which closes the fd.
+    // But the caller expects the fd to remain open for further operations.
+    Ok(bytes_written)
+}
